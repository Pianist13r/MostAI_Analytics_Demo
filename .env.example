# Яндекс.Метрика и Яндекс.Директ (один OAuth-токен покрывает оба API)
YANDEX_TOKEN=your_yandex_oauth_token
YANDEX_COUNTER_ID=your_counter_id

# Яндекс.Директ: логин агентского аккаунта (если используется агентский доступ)
DIRECT_CLIENT_LOGIN=

# Домены проекта для определения внутренних переходов (через запятую)
SITE_INTERNAL_DOMAINS=example.com,app.example.com

# Superset (сгенерируйте случайный ключ: python -c "import secrets; print(secrets.token_urlsafe(32))")
SUPERSET_SECRET_KEY=generate_random_key_here

# Учётная запись администратора Superset
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=generate_strong_password_here

# MongoDB
MONGO_USER=your_mongo_user
MONGO_PASSWORD=your_mongo_password
MONGO_HOST=your_mongo_host:port
MONGO_DB_NAME=your_database
MONGO_COLLECTION=user

# PostgreSQL (метабаза Superset + аналитическая схема analytics)
POSTGRES_DB=superset
POSTGRES_USER=superset
POSTGRES_PASSWORD=generate_strong_password_here
